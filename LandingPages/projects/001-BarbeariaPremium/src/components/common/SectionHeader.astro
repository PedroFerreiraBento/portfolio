---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center mx-auto";
---
<div class={`max-w-3xl mb-16 reveal ${alignClass}`}>
  {eyebrow && (
    <span class="text-xs font-bold uppercase tracking-[0.3em] text-[#D4AF37] block mb-4">
      {eyebrow}
    </span>
  )}
  <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl uppercase italic">
    {title}
  </h2>
  {description && (
    <p class="mt-6 text-lg leading-relaxed text-white/50">
      {description}
    </p>
  )}
</div>
