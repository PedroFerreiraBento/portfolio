---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center mx-auto";
---
<div class={`max-w-4xl mb-20 reveal ${alignClass}`}>
  {eyebrow && (
    <span class="text-xs font-black uppercase tracking-[0.3em] text-[#0EA5E9] block mb-4">
      {eyebrow}
    </span>
  )}
  <h2 class="text-4xl font-extrabold tracking-tight text-[#0F172A] sm:text-6xl uppercase">
    {title}
  </h2>
  {description && (
    <p class="mt-8 text-xl leading-relaxed text-slate-500 font-medium">
      {description}
    </p>
  )}
</div>
