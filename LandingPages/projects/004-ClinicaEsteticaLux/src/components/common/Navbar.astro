---
<header class="fixed top-0 z-50 w-full border-b border-slate-100 bg-white/80 backdrop-blur-md">
  <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-8">
    <div class="flex items-center gap-2">
      <div class="h-8 w-8 rounded-lg bg-[#0EA5E9] flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
      </div>
      <span class="text-xl font-extrabold tracking-tight text-[#0F172A] uppercase">
        Lux<span class="text-[#0EA5E9]">Clinique</span>
      </span>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden items-center gap-8 text-[12px] font-bold uppercase tracking-wider text-slate-500 lg:flex">
      <a href="#tratamentos" class="transition-colors hover:text-[#0EA5E9]">Tratamentos</a>
      <a href="#tecnologia" class="transition-colors hover:text-[#0EA5E9]">Tecnologia</a>
      <a href="#especialistas" class="transition-colors hover:text-[#0EA5E9]">Corpo Clínico</a>
      <a href="#contato" class="btn-medical py-3 px-6 text-xs">Agendar Consulta</a>
    </div>

    <!-- Mobile Button -->
    <button class="lg:hidden text-[#0F172A]">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
    </button>
  </nav>
</header>
