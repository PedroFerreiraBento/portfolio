---
import LandingLayout from "../layouts/LandingLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Services from "../components/sections/Services.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";

const page = {
  title: "L'Art des Ongles | Esmalteria Chic & Nail Bar",
  description: "A boutique de unhas mais exclusiva da cidade. Nail Art personalizada, Spa de mãos e pés e atendimento premium.",
};
---

<LandingLayout title={page.title} description={page.description}>
  <Hero />
  
  <Services />

  <!-- Showcase / Style Moment -->
  <section id="galeria" class="relative py-20 overflow-hidden bg-[#FFFBFB]">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-4 lg:grid-cols-4 lg:grid-rows-2 h-[600px]">
        <div class="reveal lg:col-span-2 lg:row-span-2 relative overflow-hidden rounded-[40px]">
          <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&q=80&w=1000" class="h-full w-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[10px] font-bold uppercase tracking-widest text-white/80">Tendência Primavera</span>
            <h4 class="text-2xl font-bold italic text-white mt-2">Soft Nude & Gold</h4>
          </div>
        </div>
        <div class="reveal lg:col-span-2 relative overflow-hidden rounded-[40px]">
          <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?auto=format&fit=crop&q=80&w=800" class="h-full w-full object-cover" />
        </div>
        <div class="reveal relative overflow-hidden rounded-[40px]">
          <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&q=80&w=600" class="h-full w-full object-cover" />
        </div>
        <div class="reveal relative overflow-hidden rounded-[40px]">
          <img src="https://images.unsplash.com/photo-1526045431048-f857369aba09?auto=format&fit=crop&q=80&w=600" class="h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <FinalCTA />
</LandingLayout>
