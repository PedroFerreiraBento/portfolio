---
import SectionHeader from "../common/SectionHeader.astro";

const testimonials = [
  {
    name: "Ana Luiza",
    role: "Digital Influencer",
    content: "Minha Nail Art dura semanas e o atendimento é sempre impecável. Não troco L'Art por nada!",
  },
  {
    name: "Beatriz Mello",
    role: "Advogada",
    content: "O ambiente é tão relaxante que o momento de fazer as unhas se torna um verdadeiro spa terapêutico.",
  },
  {
    name: "Carla Silva",
    role: "Designer",
    content: "A atenção aos detalhes e a higiene são os pontos que mais me conquistaram. Recomendadíssimo.",
  }
];
---
<section class="section-padding bg-[#FFFBFB]">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <SectionHeader 
      eyebrow="O que dizem" 
      title="A Satisfação nos Detalhes" 
      description="Nossas clientes valorizam a arte e o cuidado que colocamos em cada pincelada."
    />

    <div class="grid gap-8 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="reveal rounded-[40px] border border-[#E29595]/10 bg-white p-10 shadow-sm transition-all hover:shadow-md hover:border-[#E29595]/30">
          <div class="flex gap-1 mb-6 text-[#E29595]">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            ))}
          </div>
          <p class="text-lg leading-relaxed text-[#2D2D2D]/80 font-light italic">
            "{t.content}"
          </p>
          <div class="mt-8 border-t border-[#2D2D2D]/5 pt-6">
            <h4 class="text-sm font-bold uppercase tracking-widest text-[#2D2D2D]">{t.name}</h4>
            <span class="text-[10px] uppercase tracking-widest text-[#2D2D2D]/40 font-bold">{t.role}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
