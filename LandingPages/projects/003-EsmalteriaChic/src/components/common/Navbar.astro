<header class="fixed top-6 z-50 w-full px-6">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between rounded-full border border-white/20 bg-white/40 px-8 backdrop-blur-lg shadow-sm">
    <div class="flex items-center">
      <a href="/" class="flex items-center">
        <span class="text-xl font-bold tracking-tighter text-[#2D2D2D] uppercase italic">
          L'Art<span class="text-[#E29595] font-normal not-italic">.</span>
        </span>
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden items-center gap-10 text-[11px] font-bold uppercase tracking-[0.2em] text-[#2D2D2D]/60 lg:flex">
      <a href="#servicos" class="transition-colors hover:text-[#E29595]">Serviços</a>
      <a href="#galeria" class="transition-colors hover:text-[#E29595]">Portfolio</a>
      <a href="#contato" class="btn-chic px-6 py-2">Agendar</a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="flex h-10 w-10 items-center justify-center rounded-full bg-[#E29595]/10 lg:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E29595" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
    </button>
  </nav>
</header>
