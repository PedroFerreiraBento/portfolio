---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center mx-auto";
---
<div class={`max-w-3xl mb-16 reveal ${alignClass}`}>
  {eyebrow && (
    <span class="text-[11px] font-bold uppercase tracking-[0.4em] text-[#E29595] block mb-4">
      {eyebrow}
    </span>
  )}
  <h2 class="text-4xl font-medium tracking-tight text-[#2D2D2D] sm:text-5xl italic">
    {title}
  </h2>
  {description && (
    <p class="mt-6 text-lg leading-relaxed text-[#2D2D2D]/50 font-light">
      {description}
    </p>
  )}
</div>
