---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center mx-auto";
---
<div class={`max-w-3xl mb-20 reveal ${alignClass}`}>
  {eyebrow && (
    <span class="text-[11px] font-bold uppercase tracking-[0.4em] text-[#B88746] block mb-6">
      {eyebrow}
    </span>
  )}
  <h2 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl italic">
    {title}
  </h2>
  {description && (
    <p class="mt-8 text-lg leading-relaxed text-[#151515]/50 font-medium">
      {description}
    </p>
  )}
</div>
