---
<header class="fixed top-0 z-50 w-full border-b border-[#151515]/5 bg-white/70 backdrop-blur-xl">
  <nav class="mx-auto flex h-24 max-w-7xl items-center justify-between px-6 lg:px-8">
    <div class="flex items-center">
      <a href="/" class="flex items-center">
        <span class="text-2xl font-bold tracking-tight text-[#151515] uppercase">
          Bellezza<span class="text-[#B88746]">.</span>
        </span>
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden items-center gap-12 text-[13px] font-medium uppercase tracking-[0.15em] text-[#151515]/60 lg:flex">
      <a href="#servicos" class="transition-colors hover:text-[#151515]">Serviços</a>
      <a href="#galeria" class="transition-colors hover:text-[#151515]">Ambiente</a>
      <a href="#especialistas" class="transition-colors hover:text-[#151515]">Especialistas</a>
      <a href="#contato" class="btn-premium px-7">Agendar Agora</a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="flex h-12 w-12 items-center justify-center rounded-full bg-[#151515]/5 lg:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
    </button>
  </nav>
</header>
