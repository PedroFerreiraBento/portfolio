---
import SectionHeader from "../common/SectionHeader.astro";

const testimonials = [
  {
    author: "Mariana Costa",
    content: "O Bellezza é meu refúgio em São Paulo. O atendimento é primoroso e o ambiente é de uma paz indescritível.",
  },
  {
    author: "Helena Vaz",
    content: "Nunca encontrei especialistas tão dedicados. Minha pele e meu cabelo nunca estiveram tão saudáveis e bonitos.",
  }
];
---
<section class="section-padding bg-[#FAFAF7]">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <SectionHeader 
      eyebrow="Experiências" 
      title="Vozes de Quem Nos Escolhe" 
      description="A satisfação de nossas clientes é o nosso maior selo de qualidade e prestígio."
    />

    <div class="grid gap-20 lg:grid-cols-2 lg:gap-32">
      {testimonials.map((t) => (
        <div class="reveal">
          <div class="mb-10 text-[#B88746]">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" opacity="0.1"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C15.4647 8 15.017 8.44772 15.017 9V11.5C15.017 12.0523 14.5693 12.5 14.017 13V15.5C14.017 16.0523 13.5693 16.5 13.017 17V21H14.017ZM6.017 21L6.017 18C6.017 16.8954 6.91243 16 8.017 16H11.017C11.5693 16 12.017 15.5523 12.017 15V9C12.017 8.44772 11.5693 8 11.017 8H8.017C7.46472 8 7.017 8.44772 7.017 9V11.5C7.017 12.0523 6.56929 12.5 6.017 13V15.5C6.017 16.0523 5.56929 16.5 5.017 17V21H6.017Z"></path></svg>
          </div>
          <p class="text-2xl font-medium leading-relaxed text-[#151515] italic">
            "{t.content}"
          </p>
          <div class="mt-10 flex items-center gap-4">
            <div class="h-px w-8 bg-[#151515]/20"></div>
            <h4 class="text-xs font-bold uppercase tracking-[0.3em] text-[#151515]">{t.author}</h4>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
