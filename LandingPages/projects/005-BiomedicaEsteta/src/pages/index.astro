---
import LandingLayout from "../layouts/LandingLayout.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Treatments from "../components/sections/Treatments.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";

const page = {
  title: "Dra. Carolina Mendes | Biomedicina Estética & Harmonização",
  description: "Especialista em harmonização facial e corporal. Um refúgio de beleza e ciência no Itaim Bibi, São Paulo.",
};
---

<LandingLayout title={page.title} description={page.description}>
  <Hero />
  
  <!-- Value Bar -->
  <section class="bg-white py-12 border-y border-[#1A1A1A]/5">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-16 lg:gap-24 text-[10px] font-bold uppercase tracking-[0.4em] text-[#1A1A1A]/30">
      <div class="flex items-center gap-4">
        Certificação Biomédica
      </div>
      <div class="flex items-center gap-4">
        <span class="h-1 w-1 rounded-full bg-[#C5A059]"></span>
        Segurança & Ética
      </div>
      <div class="flex items-center gap-4">
        <span class="h-1 w-1 rounded-full bg-[#C5A059]"></span>
        Resultados Naturais
      </div>
      <div class="flex items-center gap-4">
        <span class="h-1 w-1 rounded-full bg-[#C5A059]"></span>
        Atendimento Único
      </div>
    </div>
  </section>

  <About />

  <Treatments />

  <!-- Showcase / Results Section -->
  <section id="resultados" class="section-padding bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-20">
        <div class="max-w-2xl reveal">
           <span class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#C5A059] block mb-6">Galeria de Resultados</span>
           <h2 class="text-4xl font-medium text-[#1A1A1A] sm:text-6xl">A Sutileza da <br /><span class="italic">Transformação</span></h2>
        </div>
        <p class="reveal max-w-sm text-sm leading-relaxed text-[#1A1A1A]/50 font-light">
          Respeitamos a privacidade de nossas pacientes. Abaixo, exemplos conceituais de como a harmonia e o rejuvenescimento são alcançados.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-4">
        <div class="reveal rounded-[30px] overflow-hidden aspect-square">
          <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&q=80&w=400" class="h-full w-full object-cover" />
        </div>
        <div class="reveal rounded-[30px] overflow-hidden aspect-square mt-12">
          <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&q=80&w=400" class="h-full w-full object-cover" />
        </div>
        <div class="reveal rounded-[30px] overflow-hidden aspect-square">
          <img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=400" class="h-full w-full object-cover" />
        </div>
        <div class="reveal rounded-[30px] overflow-hidden aspect-square mt-12">
          <img src="https://images.unsplash.com/photo-1522338140262-f46f5913618a?auto=format&fit=crop&q=80&w=400" class="h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</LandingLayout>
