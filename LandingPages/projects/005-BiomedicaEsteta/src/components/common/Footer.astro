---
const currentYear = new Date().getFullYear();
---
<footer class="bg-white border-t border-[#1A1A1A]/5 px-6 py-20 lg:px-8">
  <div class="mx-auto max-w-7xl flex flex-col items-center text-center">
    <div class="flex flex-col mb-12">
      <span class="text-xl font-bold tracking-[0.2em] text-[#1A1A1A] uppercase">
        Dra. Carolina Mendes
      </span>
      <span class="text-[9px] font-bold tracking-[0.4em] text-[#C5A059] uppercase">
        CRBM 123456 • São Paulo
      </span>
    </div>

    <div class="grid gap-12 lg:grid-cols-3 w-full text-sm text-[#1A1A1A]/60 font-medium">
      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-widest text-[#C5A059] mb-6">Atendimento</h4>
        <p>Rua Amauri, 250 • Itaim Bibi</p>
        <p>São Paulo - SP</p>
      </div>
      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-widest text-[#C5A059] mb-6">Horários</h4>
        <p>Segunda a Sexta: 10h às 19h</p>
        <p>Sábados: Mediante Agendamento</p>
      </div>
      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-widest text-[#C5A059] mb-6">Social</h4>
        <div class="flex justify-center gap-6">
          <a href="#" class="hover:text-[#C5A059] transition-colors">Instagram</a>
          <a href="#" class="hover:text-[#C5A059] transition-colors">WhatsApp</a>
        </div>
      </div>
    </div>

    <div class="mt-20 pt-10 border-t border-[#1A1A1A]/5 w-full">
      <p class="text-[10px] uppercase tracking-[0.3em] text-[#1A1A1A]/30">
        © {currentYear} Dra. Carolina Mendes • Desenvolvido para Portfólio
      </p>
    </div>
  </div>
</footer>
