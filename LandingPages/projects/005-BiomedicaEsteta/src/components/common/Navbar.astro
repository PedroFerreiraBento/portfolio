<header class="fixed top-0 z-50 w-full bg-white/40 backdrop-blur-md">
  <nav class="mx-auto flex h-24 max-w-7xl items-center justify-between px-6 lg:px-8">
    <div class="flex items-center">
      <a href="/" class="flex flex-col">
        <span class="text-xl font-bold tracking-[0.2em] text-[#1A1A1A] uppercase">
          Dra. Carolina Mendes
        </span>
        <span class="text-[9px] font-bold tracking-[0.4em] text-[#C5A059] uppercase">
          Biomedicina Estética
        </span>
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden items-center gap-12 text-[11px] font-bold uppercase tracking-[0.2em] text-[#1A1A1A]/60 lg:flex">
      <a href="#sobre" class="transition-colors hover:text-[#C5A059]">Sobre</a>
      <a href="#tratamentos" class="transition-colors hover:text-[#C5A059]">Tratamentos</a>
      <a href="#resultados" class="transition-colors hover:text-[#C5A059]">Resultados</a>
      <a href="#contato" class="btn-elegant py-3 px-8 text-[10px]">Agendar</a>
    </div>

    <!-- Mobile Button -->
    <button class="lg:hidden text-[#1A1A1A]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
    </button>
  </nav>
</header>
