<header class="fixed top-8 z-50 w-full px-6">
  <nav class="mx-auto flex h-14 max-w-4xl items-center justify-between rounded-full border border-white/40 bg-white/30 px-8 backdrop-blur-md shadow-sm">
    <div class="flex items-center">
      <a href="/" class="flex items-center gap-2">
        <div class="h-6 w-6 rounded-full bg-[#84A59D]/20 flex items-center justify-center">
          <div class="h-2 w-2 rounded-full bg-[#84A59D]"></div>
        </div>
        <span class="text-sm font-bold tracking-tight text-[#2D3436]">
          Psicologia Viva
        </span>
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden items-center gap-10 text-[10px] font-bold uppercase tracking-[0.2em] text-[#2D3436]/60 lg:flex">
      <a href="#sobre" class="transition-colors hover:text-[#84A59D]">A Especialista</a>
      <a href="#abordagem" class="transition-colors hover:text-[#84A59D]">Abordagem</a>
      <a href="#contato" class="text-[#84A59D]">Agendar</a>
    </div>

    <!-- Mobile Button -->
    <button class="lg:hidden text-[#2D3436]">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
    </button>
  </nav>
</header>
