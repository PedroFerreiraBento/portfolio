---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center mx-auto";
---
<div class={`max-w-4xl mb-24 reveal ${alignClass}`}>
  {eyebrow && (
    <span class="text-xs font-black uppercase tracking-[0.4em] text-[#2563EB] block mb-6">
      {eyebrow}
    </span>
  )}
  <h2 class="text-4xl font-black tracking-tight text-[#1E293B] sm:text-6xl uppercase leading-[1.1]">
    {title}
  </h2>
  {description && (
    <p class="mt-10 text-xl leading-relaxed text-slate-400 font-medium max-w-2xl mx-auto">
      {description}
    </p>
  )}
</div>
