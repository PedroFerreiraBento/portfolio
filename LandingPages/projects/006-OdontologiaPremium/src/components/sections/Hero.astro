---
---
<section class="relative min-h-screen w-full pt-32 pb-24 overflow-hidden bg-white">
  <!-- Soft abstract background shape -->
  <div class="absolute right-0 top-0 -z-10 h-[800px] w-[800px] rounded-full bg-blue-50/50 blur-3xl translate-x-1/2 -translate-y-1/2"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 py-20 lg:py-32">
    <div class="grid gap-20 lg:grid-cols-2 lg:items-center">
      <div class="reveal">
        <div class="mb-10 inline-flex items-center gap-3 rounded-full bg-blue-50 px-5 py-2 text-[10px] font-black uppercase tracking-widest text-[#2563EB]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Tecnologia & Conforto Absoluto
        </div>
        
        <h1 class="text-6xl font-black leading-[0.95] text-[#1E293B] sm:text-8xl uppercase tracking-tighter">
          Seu Sorriso, <br />
          <span class="text-[#2563EB]">Sua Identidade.</span>
        </h1>
        
        <p class="mt-10 max-w-lg text-xl leading-relaxed text-slate-400 font-medium">
          Redescubra a confiança de sorrir. Na Odonto Premium, unimos odontologia digital de alta precisão com um atendimento focado no seu bem-estar.
        </p>
        
        <div class="mt-14 flex flex-col gap-6 sm:flex-row">
          <a href="#contato" class="btn-tech px-12">
            Agendar Avaliação
          </a>
          <a href="#especialidades" class="btn-outline-tech px-12">
            Ver Serviços
          </a>
        </div>
        
        <div class="mt-20 flex items-center gap-12 border-t border-slate-50 pt-10">
          <div>
            <span class="block text-2xl font-black text-[#1E293B]">98%</span>
            <span class="text-[10px] uppercase tracking-widest font-bold text-slate-300">Satisfação</span>
          </div>
          <div class="h-10 w-px bg-slate-100"></div>
          <div>
            <span class="block text-2xl font-black text-[#1E293B]">5k+</span>
            <span class="text-[10px] uppercase tracking-widest font-bold text-slate-300">Procedimentos</span>
          </div>
        </div>
      </div>

      <div class="reveal relative">
        <div class="relative z-10 overflow-hidden rounded-[40px] shadow-2xl border-8 border-white shadow-blue-900/5">
          <img 
            src="https://images.unsplash.com/photo-1597764690523-15bea4c581c9?auto=format&fit=crop&q=80&w=1200" 
            alt="Sorriso Perfeito" 
            class="h-full w-full object-cover transition-transform duration-[5s] hover:scale-105"
          />
        </div>
        <!-- Digital elements overlay simulated -->
        <div class="absolute -right-8 -bottom-8 h-48 w-48 rounded-3xl bg-white p-6 shadow-2xl reveal hidden lg:block">
           <div class="h-full w-full rounded-2xl bg-blue-50 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
           </div>
           <span class="mt-4 block text-[9px] font-black uppercase tracking-widest text-center">Scanner 3D</span>
        </div>
      </div>
    </div>
  </div>
</section>
